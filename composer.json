{
    "name": "splitstack/aristotle",
    "description": "DDD entity scaffolding and base classes for Laravel Splitstack applications",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "ddd", "domain", "entities", "scaffolding"],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Splitstack\\Aristotle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Splitstack\\Aristotle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Splitstack\\Aristotle\\AristotleServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
    
}
